# Dependencies
node_modules/

# Build output
dist/

# Environment variables — NEVER commit these
.env
.env.local
.env.production

# Logs
npm-debug.log*

# Editor
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db

# Simulation results
sim-results/
sim-config.json
lifecycle-results/
lifecycle-config.json

# Claude Code internal tools
.claude/

# Capacitor iOS — keep the project, ignore build artifacts
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/DerivedData/
ios/.DS_Store

# Capacitor Android — keep the project, ignore build artifacts.
# Inner android/.gitignore (auto-generated by Capacitor) handles build outputs,
# Gradle caches, local.properties, generated config, etc.
android/local.properties
android/.idea/
android/.gradle/
# google-services.json contains a public Firebase API key — safe to commit
# per Google's official guidance (it identifies the project, not authenticates).
# Real auth happens via FCM Server Key (kept server-side in OneSignal).
